export default "{% block cws_development_tools_documentation %}\n<sw-page class=\"cws-development-tools-documentation\" :smart-bar-loader=\"isLoading\">\n    <template #smart-bar-header>\n        <h2>{{ $tc('cws-development-tools.documentation.title') }}</h2>\n    </template>\n\n    <template #smart-bar-actions>\n        <sw-button @click=\"goToPlugins\">\n            {{ $tc('cws-development-tools.documentation.actions.backToPlugins') }}\n        </sw-button>\n        <sw-button @click=\"goToSettings\">\n            {{ $tc('cws-development-tools.documentation.actions.openSettings') }}\n        </sw-button>\n    </template>\n\n    <template #content>\n        <sw-card-view>\n            <sw-card :title=\"documentation.title || $tc('cws-development-tools.documentation.cards.overview')\">\n                <p v-for=\"(paragraph, index) in (documentation.intro || [])\" :key=\"index\">\n                    {{ paragraph }}\n                </p>\n            </sw-card>\n\n            <sw-card\n                v-for=\"feature in features\"\n                :key=\"feature.key\"\n                :title=\"feature.title\"\n            >\n                <p>{{ feature.summary }}</p>\n\n                <div v-if=\"feature.actions && feature.actions.length > 0\" class=\"cws-development-tools-documentation__section\">\n                    <h3>{{ $tc('cws-development-tools.documentation.cards.actions') }}</h3>\n                    <ul class=\"cws-development-tools-documentation__list\">\n                        <li v-for=\"action in feature.actions\" :key=\"action\">\n                            {{ action }}\n                        </li>\n                    </ul>\n                </div>\n\n                <div v-if=\"feature.notes && feature.notes.length > 0\" class=\"cws-development-tools-documentation__section\">\n                    <h3>{{ $tc('cws-development-tools.documentation.cards.notes') }}</h3>\n                    <ul class=\"cws-development-tools-documentation__list\">\n                        <li v-for=\"note in feature.notes\" :key=\"note\">\n                            {{ note }}\n                        </li>\n                    </ul>\n                </div>\n            </sw-card>\n        </sw-card-view>\n    </template>\n</sw-page>\n{% endblock %}\n";
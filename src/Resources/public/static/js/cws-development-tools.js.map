export default "{% block cws_development_tools_index %}\n\t<sw-page class=\"cws-development-tools-index\" :smart-bar-loader=\"isLoading\">\n\t\t<template #smart-bar-header>\n\t\t\t<h2>{{ $tc('cws-development-tools.general.mainMenuItemGeneral') }}</h2>\n\t\t</template>\n\n\t\t<template #smart-bar-actions>\n\t\t\t<sw-button :disabled=\"isLoading || isBusy\" @click=\"loadState\">\n\t\t\t\t{{ $tc('cws-development-tools.index.actions.reload') }}\n\t\t\t</sw-button>\n\n\t\t\t<sw-button @click=\"goToDocumentation\">\n\t\t\t\t{{ $tc('cws-development-tools.index.actions.documentation') }}\n\t\t\t</sw-button>\n\t\t</template>\n\n\t\t<template #content>\n\t\t\t<sw-card-view>\n\t\t\t\t<sw-tabs default-item=\"maintenance\" position-identifier=\"cws-development-tools-tabs\">\n\t\t\t\t\t<template #default=\"{ active }\">\n\t\t\t\t\t\t<sw-tabs-item v-bind=\"$props\" name=\"maintenance\" :active-tab=\"active\">\n\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.tabs.maintenance') }}\n\t\t\t\t\t\t</sw-tabs-item>\n\n\t\t\t\t\t\t<sw-tabs-item v-bind=\"$props\" name=\"media-fallback\" :active-tab=\"active\">\n\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.tabs.mediaFallback') }}\n\t\t\t\t\t\t</sw-tabs-item>\n\t\t\t\t\t</template>\n\n\t\t\t\t\t<template #content=\"{ active }\">\n\t\t\t\t\t\t<template v-if=\"active === 'maintenance'\">\n\t\t\t\t\t\t\t<sw-card :title=\"$tc('cws-development-tools.index.cards.maintenance')\">\n\t\t\t\t\t\t\t\t<p>{{ $tc('cws-development-tools.index.maintenance.description') }}</p>\n\t\t\t\t\t\t\t\t<p v-if=\"!maintenanceAvailable\" class=\"cws-development-tools-index__maintenance-note\">\n\t\t\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.maintenance.devOnlyNotice') }}\n\t\t\t\t\t\t\t\t</p>\n\n\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__shop-info-box\">\n\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__shop-info-item\">\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.shopInfo.environment') }}</strong>\n\t\t\t\t\t\t\t\t\t\t<span>{{ shopEnvironmentLabel }}</span>\n\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__shop-info-item\">\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.shopInfo.httpCache') }}</strong>\n\t\t\t\t\t\t\t\t\t\t<span>{{ shopHttpCacheLabel }}</span>\n\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__shop-info-item\">\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.shopInfo.cacheAdapter') }}</strong>\n\t\t\t\t\t\t\t\t\t\t<span>{{ shopCacheAdapterLabel }}</span>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__action-grid\">\n\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__action-box\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__action-main\">\n\t\t\t\t\t\t\t\t\t\t\t<h3>{{ $tc('cws-development-tools.index.maintenance.clearCacheTitle') }}</h3>\n\t\t\t\t\t\t\t\t\t\t\t<p>{{ $tc('cws-development-tools.index.maintenance.clearCacheDescription') }}</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__action-controls\">\n\t\t\t\t\t\t\t\t\t\t\t<small class=\"cws-development-tools-index__shortcut-label\">\n\t\t\t\t\t\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.maintenance.shortcut') }}\n\t\t\t\t\t\t\t\t\t\t\t\t<code>{{ formatShortcut('C') }}</code>\n\t\t\t\t\t\t\t\t\t\t\t</small>\n\t\t\t\t\t\t\t\t\t\t\t<sw-button variant=\"primary\" :is-loading=\"isClearingCache\" :disabled=\"isLoading || isBusy\" @click=\"onClearCache\">\n\t\t\t\t\t\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.actions.clearCache') }}\n\t\t\t\t\t\t\t\t\t\t\t</sw-button>\n\t\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__result-box\" v-if=\"maintenanceResults.clearCache\">\n\t\t\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.maintenance.environment') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t\t\t{{ maintenanceResults.clearCache.environment }}</p>\n\t\t\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.maintenance.cacheStatus') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.maintenance.cacheCleared') }}</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__action-box\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__action-main\">\n\t\t\t\t\t\t\t\t\t\t\t<h3>{{ $tc('cws-development-tools.index.maintenance.compileThemesTitle') }}</h3>\n\t\t\t\t\t\t\t\t\t\t\t<p>{{ $tc('cws-development-tools.index.maintenance.compileThemesDescription') }}</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__action-controls\">\n\t\t\t\t\t\t\t\t\t\t\t<small class=\"cws-development-tools-index__shortcut-label\">\n\t\t\t\t\t\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.maintenance.shortcut') }}\n\t\t\t\t\t\t\t\t\t\t\t\t<code>{{ formatShortcut('T') }}</code>\n\t\t\t\t\t\t\t\t\t\t\t</small>\n\t\t\t\t\t\t\t\t\t\t\t<sw-button variant=\"primary\" :is-loading=\"isCompilingThemes\" :disabled=\"isLoading || isBusy || !maintenanceAvailable\" @click=\"onCompileThemes\">\n\t\t\t\t\t\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.actions.compileThemes') }}\n\t\t\t\t\t\t\t\t\t\t\t</sw-button>\n\t\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__result-box\" v-if=\"maintenanceResults.compileThemes\">\n\t\t\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.maintenance.environment') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t\t\t{{ maintenanceResults.compileThemes.environment }}</p>\n\t\t\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.maintenance.compiledSalesChannels') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t\t\t{{ maintenanceResults.compileThemes.compiledSalesChannelIds.length }}</p>\n\t\t\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.maintenance.compiledThemes') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t\t\t{{ maintenanceResults.compileThemes.compiledThemeIds.length }}</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__action-box\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__action-main\">\n\t\t\t\t\t\t\t\t\t\t\t<h3>{{ $tc('cws-development-tools.index.maintenance.clearOpcacheTitle') }}</h3>\n\t\t\t\t\t\t\t\t\t\t\t<p>{{ $tc('cws-development-tools.index.maintenance.clearOpcacheDescription') }}</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__action-controls\">\n\t\t\t\t\t\t\t\t\t\t\t<small class=\"cws-development-tools-index__shortcut-label\">\n\t\t\t\t\t\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.maintenance.shortcut') }}\n\t\t\t\t\t\t\t\t\t\t\t\t<code>{{ formatShortcut('O') }}</code>\n\t\t\t\t\t\t\t\t\t\t\t</small>\n\t\t\t\t\t\t\t\t\t\t\t<sw-button variant=\"primary\" :is-loading=\"isClearingOpcache\" :disabled=\"isLoading || isBusy || !maintenanceAvailable\" @click=\"onClearOpcache\">\n\t\t\t\t\t\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.actions.clearOpcache') }}\n\t\t\t\t\t\t\t\t\t\t\t</sw-button>\n\t\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__result-box\" v-if=\"maintenanceResults.clearOpcache\">\n\t\t\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.maintenance.environment') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t\t\t{{ maintenanceResults.clearOpcache.environment }}</p>\n\t\t\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.maintenance.opcache') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t\t\t{{ maintenanceResults.clearOpcache.opcache.message }}</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</sw-card>\n\t\t\t\t\t\t</template>\n\n\t\t\t\t\t\t<template v-if=\"active === 'media-fallback'\">\n\t\t\t\t\t\t\t<sw-card :title=\"$tc('cws-development-tools.index.cards.mediaFallback')\">\n\t\t\t\t\t\t\t\t<sw-switch-field\n\t\t\t\t\t\t\t\t\tv-model:value=\"mediaFallbackForm.enabled\"\n\t\t\t\t\t\t\t\t\t:label=\"$tc('cws-development-tools.index.mediaFallback.enabledLabel')\"\n\t\t\t\t\t\t\t\t\t:help-text=\"$tc('cws-development-tools.index.mediaFallback.enabledHelpText')\"\n\t\t\t\t\t\t\t\t/>\n\n\t\t\t\t\t\t\t\t<sw-url-field v-model:value=\"mediaFallbackForm.host\" :label=\"$tc('cws-development-tools.index.mediaFallback.fieldLabel')\" :helptext=\"$tc('cws-development-tools.index.mediaFallback.fieldHelpText')\" placeholder=\"https://example.com\"/>\n\n\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__button-row\">\n\t\t\t\t\t\t\t\t\t<sw-button variant=\"primary\" :is-loading=\"isSavingMediaFallback\" :disabled=\"isLoading || isBusy\" @click=\"onSaveMediaFallback\">\n\t\t\t\t\t\t\t\t\t\t{{ $tc('cws-development-tools.index.actions.saveMediaFallback') }}\n\t\t\t\t\t\t\t\t\t</sw-button>\n\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t<div class=\"cws-development-tools-index__status-box\">\n\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.mediaFallback.status') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t{{ mediaFallbackStatusLabel }}</p>\n\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.mediaFallback.environment') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t{{ environment || '-' }}</p>\n\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.mediaFallback.enabledState') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t{{ mediaFallback.enabled ? $tc('cws-development-tools.index.mediaFallback.yes') : $tc('cws-development-tools.index.mediaFallback.no') }}</p>\n\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.mediaFallback.configKey') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t<code>{{ mediaFallback.configKey }}</code>\n\t\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.mediaFallback.enabledConfigKey') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t<code>{{ mediaFallback.enabledConfigKey }}</code>\n\t\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.mediaFallback.value') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t{{ mediaFallback.host || '-' }}</p>\n\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.mediaFallback.source') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t{{ mediaFallbackSourceLabel }}</p>\n\t\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t\t<strong>{{ $tc('cws-development-tools.index.mediaFallback.hostScope') }}:</strong>\n\t\t\t\t\t\t\t\t\t\t{{ mediaFallback.hostScope || '-' }}</p>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</sw-card>\n\t\t\t\t\t\t</template>\n\t\t\t\t\t</template>\n\t\t\t\t</sw-tabs>\n\t\t\t</sw-card-view>\n\t\t</template>\n\t</sw-page>\n{% endblock %}\n";
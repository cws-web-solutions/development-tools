export default "<div class=\"cws-development-tools-shortcuts\">\n\t<sw-modal v-if=\"isConfirmModalOpen\" variant=\"small\" :title=\"$tc('cws-development-tools.shortcuts.confirmTitle')\" @modal-close=\"closeShortcutConfirmation\">\n\t\t{{ getShortcutConfirmationMessage() }}\n\n\t\t<template #modal-footer>\n\t\t\t<sw-button size=\"small\" @click=\"closeShortcutConfirmation\">\n\t\t\t\t{{ $tc('global.default.cancel') }}\n\t\t\t</sw-button>\n\n\t\t\t<sw-button variant=\"primary\" size=\"small\" @click=\"confirmShortcutAction\">\n\t\t\t\t{{ $tc('global.default.confirm') }}\n\t\t\t</sw-button>\n\t\t</template>\n\t</sw-modal>\n</div>\n";